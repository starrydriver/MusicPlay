---
// src/pages/index.astro
---
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>音游世界</title>
  <style>
    :root{--bg:#ffffff;--fg:#111111;--muted:#666666;--surface:#f5f5f5}
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,"Helvetica Neue",Arial;background:var(--bg);color:var(--fg);min-height:100vh}
    .container{max-width:900px;margin:0 auto;padding:1.5rem}
    .header{position:fixed;left:0;right:0;top:0;background:var(--surface);border-bottom:1px solid #e6e6e6;padding:0.75rem 1rem;display:flex;align-items:center;justify-content:space-between}
    .title{font-weight:600}
    .main{padding-top:64px}
    .hero{text-align:center;padding:2rem 0}
    .btn{display:inline-block;padding:0.6rem 1rem;border-radius:6px;border:1px solid #ddd;background:transparent;color:var(--fg);text-decoration:none}
    .options{margin:0;padding-left:1.25rem;color:var(--muted);line-height:1.8}
    .ranking-meta{display:flex;justify-content:space-between;gap:1rem;align-items:center;margin:0.5rem 0;color:var(--muted);font-size:0.95rem}
    .leaderboard{margin:0;padding:0;list-style:none;border-top:1px solid #eee}
    .leaderboard li{display:flex;justify-content:space-between;gap:1rem;padding:0.65rem 0;border-bottom:1px solid #f1f1f1;color:#444}
    .ranking-actions{display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.75rem}
    footer{padding:1.5rem;text-align:center;color:var(--muted);border-top:1px solid #eee;margin-top:2rem}
    .player{position:fixed;right:1rem;bottom:1rem;display:flex;gap:0.5rem;align-items:center}
    #musicBtn{width:44px;height:44px;border-radius:6px;border:1px solid #ddd;background:transparent;cursor:pointer}
    small{color:var(--muted)}
  </style>
</head>

<body>
  <header class="header">
    <div class="title">音游世界</div>
  </header>

  <main class="container main">
    <section class="hero">
      <h1 style="margin:0;font-size:1.8rem">音游世界</h1>
      <p style="color:var(--muted)">六键钢琴音游</p>
      <div style="margin-top:1rem">
        <a href="/game/" class="btn">进入游戏</a>
      </div>
    </section>

    <section id="features">
      <h2 style="font-size:1.1rem;margin-bottom:0.5rem">选项</h2>
      <ol class="options">
        <li><strong>简介：</strong>目前只提供《碎月》一首音乐。</li>
        <li><strong>排行榜：</strong>支持上传排行榜，实时查看得分。</li>
        <li><strong>玩法：</strong>进入游戏界面，先点击开始游戏即可游玩。(初次进入可能会有些慢，看到动态背景就说明加载好了)</li>
        <li style="color: #666; background-color: #f5f5f5; padding: 8px 12px; border-radius: 6px; list-style: none; margin-top: 8px;">
          💡 提示：支持 ASD JKL 六键游玩
        </li>
      </ol>
    </section>

    <section id="ranking" style="margin-top:1.5rem">
      <h2 style="font-size:1.1rem">排行榜</h2>
      <div class="ranking-meta">
        <span id="rankingCount">共 0 条</span>
        <span id="rankingPageInfo">1/1</span>
      </div>
      <ul id="rankingList" class="leaderboard"></ul>
      <div class="ranking-actions">
        <button id="rankingPrev" class="btn">上一页</button>
        <button id="rankingNext" class="btn">下一页</button>
      </div>
    </section>

    <section id="game" style="margin-top:1.5rem">
      <h2 style="font-size:1.1rem">开始</h2>
      <p style="color:var(--muted)">点击进入游戏页面。</p>
      <a href="/game/" class="btn">开始 →</a>
    </section>

  </main>

  <div class="player">
    <button id="musicBtn" aria-label="播放">▶</button>
    <audio id="audio" src="/audio/Can't look away.mp3"></audio>
  </div>

  <script src="../services/ranking.ts"></script>
  <script>
    const btn = document.getElementById('musicBtn');
    const audio = document.getElementById('audio');

    if (!(btn instanceof HTMLButtonElement) || !(audio instanceof HTMLAudioElement)) {
      throw new Error('播放器节点未找到');
    }

    btn.addEventListener('click', () => {
      if (audio.paused) {
        void audio.play();
        btn.textContent = '⏸';

      } else {
        audio.pause();
        btn.textContent = '▶';
      }
    });
  </script>
</body>
</html>